@model List<LibraryManagement.Models.Entities.DocGia>

@{
    ViewData["Title"] = "Quản lý độc giả";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold text-success">👨‍🎓 Quản lý độc giả</h2>
    <a asp-action="Create" class="btn btn-success">+ Thêm độc giả</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-warning">Chưa có độc giả nào.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Mã độc giả</th>
                    <th>Mã sinh viên</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Ngày sinh</th>
                    <th>Địa chỉ</th>
                    <th style="width:220px;">Chức năng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaDocGia</td>
                        <td>@item.MaSinhVien</td>
                        <td>@item.TaiKhoan?.HoTen</td>
                        <td>@item.TaiKhoan?.Email</td>
                        <td>@item.NgaySinh?.ToString("dd/MM/yyyy")</td>
                        <td>@item.DiaChi</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.MaDocGia" class="btn btn-info btn-sm text-white">Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.MaDocGia" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.MaDocGia" class="btn btn-danger btn-sm">Xoá</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}