@model List<LibraryManagement.Models.Entities.DocGia>

@{
    ViewData["Title"] = "Quản lý độc giả";
}

<div class="page-header">
    <div class="page-header-title">
        <h2>👨‍🎓 Quản lý độc giả</h2>
        <p>Theo dõi thông tin tài khoản và hồ sơ độc giả.</p>
    </div>

    <div class="toolbar-group">
        <a asp-action="Create" class="btn btn-success">+ Thêm độc giả</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        Chưa có độc giả nào trong hệ thống.
    </div>
}
else
{
    <div class="data-panel">

        <div class="mb-3">
            <input type="text"
                   class="form-control"
                   placeholder="Tìm nhanh độc giả..."
                   data-table-search="#readerTable" />
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" id="readerTable">
                <thead>
                    <tr>
                        <th>Mã độc giả</th>
                        <th>Mã sinh viên</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Ngày sinh</th>
                        <th>Địa chỉ</th>
                        <th style="width:220px;">Chức năng</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaDocGia</td>
                            <td>@item.MaSinhVien</td>
                            <td>@item.TaiKhoan?.HoTen</td>
                            <td>@item.TaiKhoan?.Email</td>
                            <td>@item.NgaySinh?.ToString("dd/MM/yyyy")</td>
                            <td>@item.DiaChi</td>
                            <td>
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@item.MaDocGia" class="btn btn-info btn-sm text-white">Chi tiết</a>
                                    <a asp-action="Edit" asp-route-id="@item.MaDocGia" class="btn btn-warning btn-sm">Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.MaDocGia" class="btn btn-danger btn-sm btn-delete-confirm">Xoá</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>
}

@section Scripts {
    <script src="~/js/table-filter.js"></script>
}