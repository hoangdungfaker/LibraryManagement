@model LibraryManagement.Models.ViewModels.ReaderFormViewModel

@{
    ViewData["Title"] = "Sửa độc giả";
}

<h2 class="fw-bold text-warning mb-4">✏️ Cập nhật độc giả</h2>
<div class="form-panel">
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="MaDocGia" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="MaSinhVien" class="form-label">Mã sinh viên</label>
            <input asp-for="MaSinhVien" class="form-control" />
            <span asp-validation-for="MaSinhVien" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="MaTaiKhoan" class="form-label">Tài khoản</label>
            <select asp-for="MaTaiKhoan" class="form-select">
                <option value="">-- Chọn tài khoản --</option>
                @foreach (var tk in Model.DanhSachTaiKhoan)
                {
                    <option value="@tk.MaTaiKhoan">@tk.HoTen - @tk.Email</option>
                }
            </select>
            <span asp-validation-for="MaTaiKhoan" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="NgaySinh" class="form-label">Ngày sinh</label>
            <input asp-for="NgaySinh" class="form-control" type="date" />
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="DiaChi" class="form-label">Địa chỉ</label>
            <input asp-for="DiaChi" class="form-control" />
        </div>
    </div>

    <button type="submit" class="btn btn-warning">Cập nhật</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}