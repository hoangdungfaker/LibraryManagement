@model List<LibraryManagement.Models.Entities.TheThuVien>

@{
    ViewData["Title"] = "Quản lý thẻ thư viện";
}

<div class="page-header">
    <div class="page-header-title">
        <h2>💳 Quản lý thẻ thư viện</h2>
        <p>Cấp thẻ, theo dõi hạn dùng và trạng thái hoạt động của thẻ độc giả.</p>
    </div>

    <div class="toolbar-group">
        <a asp-action="Create" class="btn btn-primary">+ Cấp thẻ mới</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">Chưa có thẻ thư viện nào.</div>
}
else
{
    <div class="data-panel">

        <div class="mb-3">
            <input type="text"
                   class="form-control"
                   placeholder="Tìm nhanh thẻ thư viện..."
                   data-table-search="#libraryCardTable" />
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" id="libraryCardTable">
                <thead>
                    <tr>
                        <th>Mã thẻ</th>
                        <th>Độc giả</th>
                        <th>Email</th>
                        <th>Ngày cấp</th>
                        <th>Ngày hết hạn</th>
                        <th>Trạng thái</th>
                        <th style="width:260px;">Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var card in Model)
                    {
                        <tr>
                            <td>@card.MaThe</td>
                            <td>@card.DocGia?.TaiKhoan?.HoTen</td>
                            <td>@card.DocGia?.TaiKhoan?.Email</td>
                            <td>@card.NgayCap.ToString("dd/MM/yyyy")</td>
                            <td>@card.NgayHetHan.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (card.TrangThai == "HoatDong")
                                {
                                    <span class="status-chip status-active">Hoạt động</span>
                                }
                                else if (card.TrangThai == "BiKhoa")
                                {
                                    <span class="status-chip status-locked">Bị khoá</span>
                                }
                                else
                                {
                                    <span class="status-chip status-warning">@card.TrangThai</span>
                                }
                            </td>
                            <td>
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@card.MaThe" class="btn btn-info btn-sm text-white">Chi tiết</a>
                                    <a asp-action="Extend" asp-route-id="@card.MaThe" class="btn btn-success btn-sm">Gia hạn</a>

                                    @if (card.TrangThai == "HoatDong")
                                    {
                                        <a asp-action="Lock" asp-route-id="@card.MaThe" class="btn btn-danger btn-sm">Khoá</a>
                                    }
                                    else
                                    {
                                        <a asp-action="Unlock" asp-route-id="@card.MaThe" class="btn btn-warning btn-sm">Mở</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
}

@section Scripts {
    <script src="~/js/table-filter.js"></script>
}s