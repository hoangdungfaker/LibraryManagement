@model List<LibraryManagement.Models.Entities.PhieuMuon>

@{
    ViewData["Title"] = "Quản lý mượn sách";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold text-success">📚 Quản lý mượn sách</h2>
    <div>
        <a asp-action="Create" class="btn btn-success">+ Lập phiếu mượn</a>
        <a asp-action="RenewList" class="btn btn-warning">Gia hạn</a>
        <a asp-action="ReturnList" class="btn btn-danger">Trả sách</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-warning">Chưa có phiếu mượn nào.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Mã phiếu</th>
                    <th>Độc giả</th>
                    <th>Nhân viên</th>
                    <th>Ngày mượn</th>
                    <th>Hạn trả</th>
                    <th>Trạng thái</th>
                    <th>Số sách</th>
                    <th>Chức năng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaPhieu</td>
                        <td>@item.TheThuVien?.DocGia?.TaiKhoan?.HoTen</td>
                        <td>@item.NhanVien?.TaiKhoan?.HoTen</td>
                        <td>@item.NgayMuon.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.HanTra.ToString("dd/MM/yyyy")</td>
                        <td>@item.TrangThai</td>
                        <td>@item.ChiTietPhieuMuons.Count</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.MaPhieu" class="btn btn-info btn-sm text-white">Chi tiết</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}