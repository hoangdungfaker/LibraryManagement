@model List<LibraryManagement.Models.Entities.PhieuMuon>

@{
    ViewData["Title"] = "Quản lý mượn sách";
}

<div class="page-header">
    <div class="page-header-title">
        <h2>🔄 Quản lý mượn trả</h2>
        <p>Theo dõi phiếu mượn, xử lý trả sách, gia hạn và kiểm soát trạng thái mượn.</p>
    </div>

    <div class="toolbar-group">
        <a asp-action="Create" class="btn btn-success">+ Lập phiếu mượn</a>
        <a asp-action="RenewList" class="btn btn-warning">Gia hạn</a>
        <a asp-action="ReturnList" class="btn btn-danger">Trả sách</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <div class="empty-state">Chưa có phiếu mượn nào.</div>
}
else
{
    <div class="data-panel">

        <div class="mb-3">
            <input type="text"
                   class="form-control"
                   placeholder="Tìm nhanh phiếu mượn..."
                   data-table-search="#borrowTable" />
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle" id="borrowTable">
                <thead>
                    <tr>
                        <th>Mã phiếu</th>
                        <th>Độc giả</th>
                        <th>Nhân viên</th>
                        <th>Ngày mượn</th>
                        <th>Hạn trả</th>
                        <th>Trạng thái</th>
                        <th>Số sách</th>
                        <th>Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaPhieu</td>
                            <td>@item.TheThuVien?.DocGia?.TaiKhoan?.HoTen</td>
                            <td>@item.NhanVien?.TaiKhoan?.HoTen</td>
                            <td>@item.NgayMuon.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.HanTra.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (item.TrangThai == "DangMuon")
                                {
                                    <span class="status-chip status-active">Đang mượn</span>
                                }
                                else if (item.TrangThai == "DaTra")
                                {
                                    <span class="status-chip status-active">Đã trả</span>
                                }
                                else
                                {
                                    <span class="status-chip status-warning">@item.TrangThai</span>
                                }
                            </td>
                            <td>@item.ChiTietPhieuMuons.Count</td>
                            <td>
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@item.MaPhieu" class="btn btn-info btn-sm text-white">Chi tiết</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
}

@section Scripts {
    <script src="~/js/table-filter.js"></script>
}