@model List<LibraryManagement.Models.Entities.PhieuMuon>

@{
    ViewData["Title"] = "Lịch sử mượn";
}

<h2 class="fw-bold text-primary mb-4">📚 Lịch sử mượn sách</h2>

@if (!Model.Any())
{
    <div class="alert alert-warning">Bạn chưa có lịch sử mượn sách.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Mã phiếu</th>
                    <th>Ngày mượn</th>
                    <th>Hạn trả</th>
                    <th>Trạng thái</th>
                    <th>Số sách</th>
                    <th>Chi tiết</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaPhieu</td>
                        <td>@item.NgayMuon.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.HanTra.ToString("dd/MM/yyyy")</td>
                        <td>@item.TrangThai</td>
                        <td>@item.ChiTietPhieuMuons.Count</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.MaPhieu" class="btn btn-info btn-sm text-white">Xem</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}