<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryManagement</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
</head>
<body>

    @if (Context.Session.GetInt32("MaTaiKhoan") != null)
    {
        <nav class="navbar navbar-expand-xl navbar-custom">
            <div class="container-fluid px-4">

                <a class="navbar-brand brand-custom" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">📚</span>
                    <span>LibraryManagement</span>
                </a>

                <button class="navbar-toggler navbar-toggler-custom" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <div class="navbar-nav me-auto align-items-xl-center">
                        <a class="nav-link menu-link" asp-controller="Home" asp-action="Index">Trang chủ</a>

                        @if (Context.Session.GetString("VaiTro") == "Admin")
                        {
                            <a class="nav-link menu-link" asp-controller="Book" asp-action="Index">Quản lý sách</a>
                            <a class="nav-link menu-link" asp-controller="Reader" asp-action="Index">Độc giả</a>
                            <a class="nav-link menu-link" asp-controller="Staff" asp-action="Index">Nhân viên</a>
                            <a class="nav-link menu-link" asp-controller="LibraryCard" asp-action="Index">Thẻ thư viện</a>
                            <a class="nav-link menu-link" asp-controller="Borrow" asp-action="Index">Mượn trả</a>
                            <a class="nav-link menu-link" asp-controller="Report" asp-action="Index">Báo cáo</a>
                            <a class="nav-link menu-link" asp-controller="Notification" asp-action="Index">Thông báo</a>
                        }

                        @if (Context.Session.GetString("VaiTro") == "ThuThu")
                        {
                            <a class="nav-link menu-link" asp-controller="Book" asp-action="Index">Quản lý sách</a>
                            <a class="nav-link menu-link" asp-controller="Reader" asp-action="Index">Độc giả</a>
                            <a class="nav-link menu-link" asp-controller="LibraryCard" asp-action="Index">Thẻ thư viện</a>
                            <a class="nav-link menu-link" asp-controller="Borrow" asp-action="Index">Mượn trả</a>
                            <a class="nav-link menu-link" asp-controller="Notification" asp-action="Index">Thông báo</a>
                        }

                        @if (Context.Session.GetString("VaiTro") == "DocGia")
                        {
                            <a class="nav-link menu-link" asp-controller="Book" asp-action="Index">Tra cứu sách</a>
                            <a class="nav-link menu-link" asp-controller="Borrow" asp-action="History">Lịch sử mượn</a>
                            <a class="nav-link menu-link" asp-controller="Notification" asp-action="Index">Thông báo</a>
                        }
                    </div>

                    <div class="header-user-box">
                        <div class="user-chip">👤 @Context.Session.GetString("HoTen")</div>
                        <div class="role-chip">@Context.Session.GetString("VaiTro")</div>
                        <a asp-controller="Account" asp-action="Logout" class="logout-btn">Đăng xuất</a>
                    </div>
                </div>
            </div>
        </nav>
    }

    <main class="page-shell">
        <div class="container-fluid page-container px-3 px-lg-4">
            <div class="content-panel">
                @RenderBody()
            </div>
        </div>
    </main>

    <footer class="footer-custom">
        <div class="container-fluid text-center">
            © 2026 - LibraryManagement | Hệ thống quản lý thư viện
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>