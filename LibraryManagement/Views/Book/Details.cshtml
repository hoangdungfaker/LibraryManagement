@model LibraryManagement.Models.Entities.Sach

@{
    ViewData["Title"] = "Chi tiết sách";
}

<div class="book-detail-page">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="detail-book-cover">
                <div class="detail-book-icon">📚</div>
                <div class="detail-book-title">@Model.TenSach</div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="detail-info-box">
                <h2 class="detail-title">@Model.TenSach</h2>

                <div class="detail-meta">
                    <p><strong>Tác giả:</strong> @Model.TacGia</p>
                    <p><strong>Thể loại:</strong> @(string.IsNullOrWhiteSpace(Model.TheLoai) ? "Chưa cập nhật" : Model.TheLoai)</p>
                    <p><strong>Nhà xuất bản:</strong> @(string.IsNullOrWhiteSpace(Model.NhaXuatBan) ? "Chưa cập nhật" : Model.NhaXuatBan)</p>
                    <p><strong>Năm xuất bản:</strong> @(Model.NamXuatBan.HasValue? Model.NamXuatBan.ToString() : "Chưa cập nhật")</p>
                    <p><strong>Vị trí:</strong> @(string.IsNullOrWhiteSpace(Model.ViTri) ? "Chưa cập nhật" : Model.ViTri)</p>
                    <p><strong>Mã sách:</strong> @Model.MaSach</p>
                </div>

                <div class="detail-description mt-4">
                    <h5>Giới thiệu sách</h5>
                    <p>
                        Đây là đầu sách thuộc hệ thống thư viện, phục vụ cho nhu cầu học tập, nghiên cứu và tra cứu tài liệu.
                        Người dùng có thể tìm kiếm, xem thông tin chi tiết, theo dõi lịch sử mượn và sử dụng sách theo quyền hạn được cấp.
                    </p>
                    <p>
                        Nội dung hiển thị ở đây có thể mở rộng thêm phần mô tả dài, tóm tắt sách, từ khóa, số lượng bản sao,
                        trạng thái còn sách hoặc các thông tin nghiệp vụ khác của thư viện.
                    </p>
                </div>

                <div class="mt-4 d-flex gap-2 flex-wrap">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>

                    @if (Context.Session.GetString("VaiTro") == "Admin" || Context.Session.GetString("VaiTro") == "ThuThu")
                    {
                        <a asp-action="Edit" asp-route-id="@Model.MaSach" class="btn btn-warning">Sửa sách</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>