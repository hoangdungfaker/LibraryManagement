@model LibraryManagement.Models.Entities.Sach

@{
    ViewData["Title"] = "Xoá sách";
}

<h2 class="fw-bold text-danger mb-4">🗑️ Xác nhận xoá sách</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <p><strong>Mã sách:</strong> @Model.MaSach</p>
        <p><strong>Tên sách:</strong> @Model.TenSach</p>
        <p><strong>Tác giả:</strong> @Model.TacGia</p>
        <p><strong>Thể loại:</strong> @Model.TheLoai</p>
        <p><strong>Nhà xuất bản:</strong> @Model.NhaXuatBan</p>
        <p><strong>Năm xuất bản:</strong> @Model.NamXuatBan</p>
        <p><strong>Vị trí:</strong> @Model.ViTri</p>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="MaSach" />
            <button type="submit" class="btn btn-danger">Xác nhận xoá</button>
            <a asp-action="Index" class="btn btn-secondary">Huỷ</a>
        </form>
    </div>
</div>