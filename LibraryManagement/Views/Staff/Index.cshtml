@model List<LibraryManagement.Models.Entities.NhanVien>

@{
    ViewData["Title"] = "Quản lý nhân viên";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="fw-bold text-warning">👨‍💼 Quản lý nhân viên</h2>
    <a asp-action="Create" class="btn btn-warning">+ Thêm nhân viên</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-warning">Chưa có nhân viên nào.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Mã nhân viên</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Chức vụ</th>
                    <th>Số phiếu mượn đã lập</th>
                    <th style="width:220px;">Chức năng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaNhanVien</td>
                        <td>@item.TaiKhoan?.HoTen</td>
                        <td>@item.TaiKhoan?.Email</td>
                        <td>@item.ChucVu</td>
                        <td>@item.PhieuMuons.Count</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.MaNhanVien" class="btn btn-info btn-sm text-white">Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.MaNhanVien" class="btn btn-warning btn-sm">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.MaNhanVien" class="btn btn-danger btn-sm">Xoá</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}