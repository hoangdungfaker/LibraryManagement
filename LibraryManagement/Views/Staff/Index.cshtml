@model List<LibraryManagement.Models.Entities.NhanVien>

@{
    ViewData["Title"] = "Quản lý nhân viên";
}

<div class="page-header">
    <div class="page-header-title">
        <h2>👨‍💼 Quản lý nhân viên</h2>
        <p>Quản lý thông tin nhân viên thư viện và vai trò vận hành hệ thống.</p>
    </div>

    <div class="toolbar-group">
        <a asp-action="Create" class="btn btn-warning">+ Thêm nhân viên</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="empty-state">Chưa có nhân viên nào.</div>
}
else
{
    <div class="data-panel">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead>
                    <tr>
                        <th>Mã nhân viên</th>
                        <th>Họ tên</th>
                        <th>Email</th>
                        <th>Chức vụ</th>
                        <th>Số phiếu mượn đã lập</th>
                        <th style="width:220px;">Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.MaNhanVien</td>
                            <td>@item.TaiKhoan?.HoTen</td>
                            <td>@item.TaiKhoan?.Email</td>
                            <td>@item.ChucVu</td>
                            <td>@item.PhieuMuons.Count</td>
                            <td>
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@item.MaNhanVien" class="btn btn-info btn-sm text-white">Chi tiết</a>
                                    <a asp-action="Edit" asp-route-id="@item.MaNhanVien" class="btn btn-warning btn-sm">Sửa</a>
                                    <a asp-action="Delete" asp-route-id="@item.MaNhanVien" class="btn btn-danger btn-sm">Xoá</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}