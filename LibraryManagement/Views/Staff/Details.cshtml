@model LibraryManagement.Models.Entities.NhanVien

@{
    ViewData["Title"] = "Chi tiết nhân viên";
}

<h2 class="fw-bold text-info mb-4">👨‍💼 Chi tiết nhân viên</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <p><strong>Mã nhân viên:</strong> @Model.MaNhanVien</p>
        <p><strong>Họ tên:</strong> @Model.TaiKhoan?.HoTen</p>
        <p><strong>Email:</strong> @Model.TaiKhoan?.Email</p>
        <p><strong>Chức vụ:</strong> @Model.ChucVu</p>
        <p><strong>Số phiếu mượn đã lập:</strong> @Model.PhieuMuons.Count</p>

        <a asp-action="Edit" asp-route-id="@Model.MaNhanVien" class="btn btn-warning">Sửa</a>
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>