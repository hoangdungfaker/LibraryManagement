@{
    ViewData["Title"] = "Trang chủ";
    var hoTen = Context.Session.GetString("HoTen");
    var vaiTro = Context.Session.GetString("VaiTro");
}

<div class="library-home">
    <div class="hero-section mb-4">
        <div class="hero-overlay">
            <div class="hero-content">
                <h1>📚 Không gian thư viện số hiện đại</h1>
                <p>Xin chào <strong>@hoTen</strong> — khám phá kho sách, tra cứu nhanh và sử dụng hệ thống thư viện thông minh.</p>

                <form class="search-bar mt-4" method="get" asp-controller="Book" asp-action="Index">
                    <input type="text" name="keyword" placeholder="Tìm kiếm theo tên sách..." />
                    <button type="submit">Tìm sách</button>
                </form>
            </div>
        </div>
    </div>

    <div class="row g-4 align-items-stretch">
        <div class="col-lg-4">
            <div class="home-info-card h-100">
                <h3>🌟 Chào mừng đến thư viện</h3>
                <p>
                    Hệ thống hỗ trợ tra cứu sách, theo dõi lịch sử mượn, quản lý độc giả, mượn trả,
                    gia hạn và thống kê thư viện.
                </p>

                <div class="quick-tags">
                    <span class="quick-tag">Sách công nghệ</span>
                    <span class="quick-tag">Lập trình</span>
                    <span class="quick-tag">Cơ sở dữ liệu</span>
                    <span class="quick-tag">Kỹ năng</span>
                </div>

                <div class="mt-4">
                    <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Khám phá sách</a>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="home-highlight-card h-100">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="highlight-mini-card">
                            <div class="mini-icon">📘</div>
                            <h5>Kho sách đa dạng</h5>
                            <p>Quản lý đầu sách theo thể loại, tác giả, vị trí và tình trạng.</p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="highlight-mini-card">
                            <div class="mini-icon">🕘</div>
                            <h5>Lịch sử mượn rõ ràng</h5>
                            <p>Theo dõi mượn trả, gia hạn và trạng thái phiếu một cách trực quan.</p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="highlight-mini-card">
                            <div class="mini-icon">🔔</div>
                            <h5>Thông báo thông minh</h5>
                            <p>Nhắc hạn trả, thông báo vi phạm và cập nhật thông tin nhanh chóng.</p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="highlight-mini-card">
                            <div class="mini-icon">📊</div>
                            <h5>Báo cáo trực quan</h5>
                            <p>Biểu đồ, thống kê đầu sách, độc giả, tiền phạt và lượt mượn.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="section-title mt-5 mb-3">
        <h3>🚀 Truy cập nhanh</h3>
    </div>

    <div class="row g-3 mb-5">
        @if (vaiTro == "Admin")
        {
            <div class="col-md-3">
                <div class="feature-card">
                    <h5>📘 Quản lý sách</h5>
                    <p>Thêm, sửa, xoá và tra cứu đầu sách trong hệ thống.</p>
                    <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Truy cập</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="feature-card">
                    <h5>👨‍🎓 Độc giả</h5>
                    <p>Quản lý hồ sơ độc giả và trạng thái thẻ thư viện.</p>
                    <a asp-controller="Reader" asp-action="Index" class="btn btn-success">Truy cập</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="feature-card">
                    <h5>🔄 Mượn trả</h5>
                    <p>Xử lý toàn bộ nghiệp vụ mượn, trả, gia hạn và phạt.</p>
                    <a asp-controller="Borrow" asp-action="Index" class="btn btn-warning">Truy cập</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="feature-card">
                    <h5>📊 Báo cáo</h5>
                    <p>Xem thống kê tổng quan và biểu đồ hoạt động thư viện.</p>
                    <a asp-controller="Report" asp-action="Index" class="btn btn-dark">Truy cập</a>
                </div>
            </div>
        }

        @if (vaiTro == "ThuThu")
        {
            <div class="col-md-4">
                <div class="feature-card">
                    <h5>📘 Quản lý sách</h5>
                    <p>Thêm, sửa, tra cứu và xem chi tiết đầu sách.</p>
                    <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Truy cập</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h5>👨‍🎓 Độc giả</h5>
                    <p>Quản lý độc giả, thẻ thư viện và thông tin liên quan.</p>
                    <a asp-controller="Reader" asp-action="Index" class="btn btn-success">Truy cập</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h5>🔄 Mượn trả</h5>
                    <p>Xử lý mượn sách, trả sách và gia hạn phiếu mượn.</p>
                    <a asp-controller="Borrow" asp-action="Index" class="btn btn-warning">Truy cập</a>
                </div>
            </div>
        }

        @if (vaiTro == "DocGia")
        {
            <div class="col-md-4">
                <div class="feature-card">
                    <h5>📚 Tra cứu sách</h5>
                    <p>Tìm kiếm theo tên sách, lọc theo thể loại và xem chi tiết.</p>
                    <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Truy cập</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h5>🕘 Lịch sử mượn</h5>
                    <p>Xem các phiếu mượn, hạn trả và trạng thái hiện tại.</p>
                    <a asp-controller="Borrow" asp-action="History" class="btn btn-success">Truy cập</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h5>🔔 Thông báo</h5>
                    <p>Xem thông báo cá nhân và các nhắc nhở từ thư viện.</p>
                    <a asp-controller="Notification" asp-action="Index" class="btn btn-dark">Truy cập</a>
                </div>
            </div>
        }
    </div>
</div>