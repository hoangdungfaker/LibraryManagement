@{
    ViewData["Title"] = "Trang chủ";
    var hoTen = Context.Session.GetString("HoTen");
    var vaiTro = Context.Session.GetString("VaiTro");
}

<div class="library-home">

    <div class="hero-section mb-4">
        <div class="hero-overlay">
            <div class="hero-content">
                <h1>📚 Hệ thống quản lý thư viện</h1>
                <p>Chào mừng <strong>@hoTen</strong> đến với không gian đọc sách hiện đại.</p>

                <form class="search-bar mt-3" method="get" asp-controller="Book" asp-action="Index">
                    <input type="text" name="keyword" placeholder="Tìm kiếm sách theo tên, tác giả, thể loại..." />
                    <button type="submit">Tìm kiếm</button>
                </form>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-3">
            <div class="category-box">
                <h4>📂 Danh mục sách</h4>
                <ul class="category-list">
                    <li>Công nghệ thông tin</li>
                    <li>Khoa học dữ liệu</li>
                    <li>Lập trình Web</li>
                    <li>Cơ sở dữ liệu</li>
                    <li>Kỹ năng mềm</li>
                    <li>Tiểu thuyết</li>
                    <li>Lịch sử</li>
                    <li>Văn học</li>
                </ul>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="book-banner">
                <div class="book-banner-content">
                    <h2>Không gian sách dành cho bạn</h2>
                    <p>Khám phá tri thức mỗi ngày với thư viện trực tuyến thông minh.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="section-title mt-5 mb-3">
        <h3>🔥 Chức năng nhanh</h3>
    </div>

    <div class="row g-3 mb-5">
        @if (vaiTro == "Admin")
        {
            <div class="col-md-3">
                <div class="feature-card">
                    <h5>📘 Quản lý sách</h5>
                    <p>Thêm, sửa, xoá và tra cứu đầu sách.</p>
                    <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Truy cập</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="feature-card">
                    <h5>👨‍🎓 Độc giả</h5>
                    <p>Quản lý hồ sơ độc giả và tài khoản.</p>
                    <a asp-controller="Reader" asp-action="Index" class="btn btn-success">Truy cập</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="feature-card">
                    <h5>🔄 Mượn trả</h5>
                    <p>Xử lý mượn, trả, gia hạn và phạt.</p>
                    <a asp-controller="Borrow" asp-action="Index" class="btn btn-warning">Truy cập</a>
                </div>
            </div>

            <div class="col-md-3">
                <div class="feature-card">
                    <h5>📊 Báo cáo</h5>
                    <p>Xem tổng quan số liệu thư viện.</p>
                    <a asp-controller="Report" asp-action="Index" class="btn btn-dark">Truy cập</a>
                </div>
            </div>
        }

        @if (vaiTro == "ThuThu")
        {
            <div class="col-md-4">
                <div class="feature-card">
                    <h5>📘 Quản lý sách</h5>
                    <p>Thêm, sửa và tra cứu đầu sách.</p>
                    <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Truy cập</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h5>👨‍🎓 Độc giả</h5>
                    <p>Quản lý độc giả và thẻ thư viện.</p>
                    <a asp-controller="Reader" asp-action="Index" class="btn btn-success">Truy cập</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h5>🔄 Mượn trả</h5>
                    <p>Xử lý mượn, trả và gia hạn sách.</p>
                    <a asp-controller="Borrow" asp-action="Index" class="btn btn-warning">Truy cập</a>
                </div>
            </div>
        }

        @if (vaiTro == "DocGia")
        {
            <div class="col-md-4">
                <div class="feature-card">
                    <h5>📚 Tra cứu sách</h5>
                    <p>Tìm kiếm đầu sách theo nhu cầu của bạn.</p>
                    <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Truy cập</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h5>🕘 Lịch sử mượn</h5>
                    <p>Xem các phiếu mượn và trạng thái hiện tại.</p>
                    <a asp-controller="Borrow" asp-action="History" class="btn btn-success">Truy cập</a>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <h5>🔔 Thông báo</h5>
                    <p>Xem thông báo và nhắc nợ từ thư viện.</p>
                    <a asp-controller="Notification" asp-action="Index" class="btn btn-dark">Truy cập</a>
                </div>
            </div>
        }
    </div>

    <div class="section-title mb-3">
        <h3>📖 Sách nổi bật</h3>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="book-card">
                <div class="book-cover">📘</div>
                <h5>Lập trình C# cơ bản</h5>
                <p>Tác giả: Nguyễn Văn B</p>
                <a asp-controller="Book" asp-action="Index" class="btn btn-outline-primary btn-sm">Xem thêm</a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="book-card">
                <div class="book-cover">📙</div>
                <h5>Cơ sở dữ liệu</h5>
                <p>Tác giả: Trần Văn C</p>
                <a asp-controller="Book" asp-action="Index" class="btn btn-outline-primary btn-sm">Xem thêm</a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="book-card">
                <div class="book-cover">📗</div>
                <h5>ASP.NET MVC</h5>
                <p>Tác giả: Lê Văn D</p>
                <a asp-controller="Book" asp-action="Index" class="btn btn-outline-primary btn-sm">Xem thêm</a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="book-card">
                <div class="book-cover">📕</div>
                <h5>Kỹ năng làm việc nhóm</h5>
                <p>Tác giả: Nhiều tác giả</p>
                <a asp-controller="Book" asp-action="Index" class="btn btn-outline-primary btn-sm">Xem thêm</a>
            </div>
        </div>
    </div>
</div>