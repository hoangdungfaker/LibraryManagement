@model List<LibraryManagement.Models.Entities.ThongBao>

@{
    ViewData["Title"] = "Thông báo";
    var role = Context.Session.GetString("VaiTro");
}

<div class="page-header">
    <div class="page-header-title">
        <h2>🔔 Thông báo hệ thống</h2>
        <p>Quản lý thông báo gửi tới người dùng và theo dõi trạng thái đã đọc.</p>
    </div>

    @if (role == "Admin" || role == "ThuThu")
    {
        <div class="toolbar-group">
            <a asp-action="Create" class="btn btn-primary">+ Gửi thông báo</a>
            <form asp-action="SendOverdue" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger">Gửi nhắc nợ quá hạn</button>
            </form>
        </div>
    }
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!Model.Any())
{
    <div class="empty-state">Chưa có thông báo nào.</div>
}
else
{
    <div class="data-panel">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead>
                    <tr>
                        <th>Mã</th>
                        @if (role == "Admin" || role == "ThuThu")
                        {
                            <th>Người nhận</th>
                            <th>Email</th>
                        }
                        <th>Nội dung</th>
                        <th>Ngày gửi</th>
                        <th>Trạng thái</th>
                        <th>Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.DaDoc ? "" : "table-warning")">
                            <td>@item.MaThongBao</td>

                            @if (role == "Admin" || role == "ThuThu")
                            {
                                <td>@item.TaiKhoan?.HoTen</td>
                                <td>@item.TaiKhoan?.Email</td>
                            }

                            <td>
                                @(item.NoiDung.Length > 80 ? item.NoiDung.Substring(0, 80) + "..." : item.NoiDung)
                            </td>
                            <td>@item.NgayGui.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (item.DaDoc)
                                {
                                    <span class="status-chip status-active">Đã đọc</span>
                                }
                                else
                                {
                                    <span class="status-chip status-locked">Chưa đọc</span>
                                }
                            </td>
                            <td>
                                <div class="table-actions">
                                    <a asp-action="Details" asp-route-id="@item.MaThongBao" class="btn btn-info btn-sm text-white">Xem</a>

                                    @if (role == "DocGia" && !item.DaDoc)
                                    {
                                        <form asp-action="MarkAsRead" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.MaThongBao" />
                                            <button type="submit" class="btn btn-success btn-sm">Đánh dấu</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}